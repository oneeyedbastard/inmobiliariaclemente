<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    ### 1. Redirección HTTPS (compatible con Cloudflare) ###
    RewriteCond %{HTTP:CF-Visitor} '"scheme":"http"'
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301,NE]

    ### 2. Manejo de cabecera Authorization (API/Laravel) ###
    RewriteCond %{HTTP:Authorization} ^(.+)$
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    ### 3. Eliminar trailing slashes (SEO-friendly) ###
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301,NE]

    ### 4. Front Controller (Laravel) ###
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

### ========== OPTIMIZACIÓN DE CACHÉ (ESTÁTICOS) ========== ###
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"

    # CSS y JS (Laravel Breeze + Tailwind)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"

    # Imágenes (WebP, PNG, JPEG, SVG)
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # Fuentes (Tailwind, Font Awesome)
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
</IfModule>

### ========== CABECERAS DE SEGURIDAD ========== ###
<IfModule mod_headers.c>
    # Protección contra XSS, Clickjacking y MIME-sniffing
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # HSTS (Solo activar si HTTPS está bien configurado)
    # Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Caché para archivos estáticos (Cloudflare compatible)
    <FilesMatch "\.(css|js|jpg|jpeg|png|webp|svg|ico|woff2?)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Deshabilitar caché para rutas de autenticación (Breeze)
    <LocationMatch "^/(login|register|forgot-password|reset-password|email/verify)">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </LocationMatch>
</IfModule>

### ========== COMPRESIÓN GZIP (MEJORA CLOUDFLARE) ========== ###
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE text/xml application/xml image/svg+xml
    AddOutputFilterByType DEFLATE font/woff2 application/font-woff2
</IfModule>

### ========== PROTECCIÓN DE ARCHIVOS SENSIBLES ========== ###
<Files .htaccess>
    Require all denied
</Files>

<FilesMatch "^(\.env|composer\.json|composer\.lock|package\.json)$">
    Require all denied
</FilesMatch>

# Bloquear acceso a directorios
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>
